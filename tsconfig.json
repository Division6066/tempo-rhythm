{
  "extends": "./tsconfig.base.json",
  "compilerOptions": {
    "jsx": "react-jsx",
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "paths": {
      "@/*": ["./apps/mobile/*"],
      "@/convex/*": ["./convex/*"]
    },
    "types": ["bun", "node"]
  },
  "include": [
    "apps/mobile/nativewind-env.d.ts",
    "apps/mobile/app/(tempo)/routines.tsx",
    "apps/mobile/lib/**/*.ts"
  ],
  "exclude": ["node_modules", "dist", ".turbo", "**/e2e/**"]
}
