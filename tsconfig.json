{
  "extends": "./tsconfig.base.json",
  "compilerOptions": {
    "jsx": "react-jsx",
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "paths": {
      "@/*": ["./apps/mobile/*"]
    },
    "types": ["bun", "node"]
  },
  "include": [
    "apps/mobile/app/(tempo)/theme.tsx",
    "apps/mobile/e2e/**/*.ts",
    "apps/mobile/src/**/*",
    "packages/theme/src/**/*"
  ]
}
