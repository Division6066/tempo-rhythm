{
  "extends": "./tsconfig.base.json",
  "compilerOptions": {
    "jsx": "react-jsx",
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "paths": {
      "@/*": ["./apps/mobile/*"]
    },
    "types": ["bun", "node"]
  },
  "include": [
    "apps/mobile/app/(tempo)/settings.tsx",
    "apps/mobile/e2e/settings.spec.ts",
    "apps/mobile/lib/prefsStore.ts"
  ]
}
