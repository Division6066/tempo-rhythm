{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://tempo.flow/schemas/implementation-matrix/screens.schema.json",
  "title": "Tempo UI Screens Matrix",
  "description": "Canonical screen inventory mapping prototype → repo route.",
  "type": "object",
  "required": ["version", "generated", "screens"],
  "properties": {
    "$schema": { "type": "string" },
    "version": { "type": "string", "pattern": "^\\d+\\.\\d+\\.\\d+$" },
    "generated": { "type": "string", "format": "date" },
    "generatedBy": { "type": "string" },
    "sources": { "type": "object", "additionalProperties": { "type": "string" } },
    "statusLegend": { "type": "object", "additionalProperties": { "type": "string" } },
    "ownerAgents": { "type": "object", "additionalProperties": { "type": "string" } },
    "platforms": {
      "type": "array",
      "items": { "enum": ["web", "mobile"] }
    },
    "screens": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/screen" }
    }
  },
  "$defs": {
    "screen": {
      "type": "object",
      "required": ["slug", "title", "category", "platform", "route", "sourceFiles", "status", "owner", "priority"],
      "additionalProperties": false,
      "properties": {
        "slug": { "type": "string", "pattern": "^[a-z][a-z0-9-]*$" },
        "title": { "type": "string", "minLength": 1 },
        "category": { "enum": ["Flow", "Library", "You", "Settings", "Marketing", "Onboarding", "Mobile"] },
        "platform": { "enum": ["web", "mobile"] },
        "route": { "type": "string", "minLength": 1 },
        "currentRoute": { "type": "string" },
        "bare": { "type": "boolean" },
        "deprecated": { "type": "boolean" },
        "icon": { "type": "string" },
        "sourceFiles": { "type": "array", "items": { "type": "string" } },
        "status": { "enum": ["missing", "scaffold", "partial", "ported", "wired", "shipped"] },
        "owner": { "type": "string" },
        "priority": { "enum": ["P0", "P1", "P2", "P3", "P4"] },
        "queries": { "type": "array", "items": { "type": "string" } },
        "mutations": { "type": "array", "items": { "type": "string" } },
        "actions": { "type": "array", "items": { "type": "string" } },
        "auth": { "enum": ["public", "required", "owner"] },
        "streaming": { "type": "boolean" },
        "notes": { "type": "string" }
      }
    }
  }
}
