{
  "expo": {
    "name": "TEMPO Flow",
    "slug": "tempo-flow",
    "version": "0.1.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "scheme": "tempoflow",
    "userInterfaceStyle": "dark",
    "newArchEnabled": true,
    "splash": {
      "backgroundColor": "#1A1A2E",
      "resizeMode": "contain"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.tempoflow.app"
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#1A1A2E"
      },
      "package": "com.tempoflow.app"
    },
    "web": {
      "bundler": "metro",
      "favicon": "./assets/icon.png"
    },
    "plugins": ["expo-router", "expo-secure-store"],
    "extra": {
      "eas": {
        "projectId": "90dfac90-0baa-461b-946c-351d2306e607"
      }
    }
  }
}
