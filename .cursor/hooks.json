{
  "version": 1,
  "hooks": {
    "sessionStart": [
      {
        "command": "node .cursor/hooks/session-start.mjs",
        "timeout": 10
      }
    ],
    "stop": [
      {
        "command": "node .cursor/hooks/stop-logger.mjs",
        "timeout": 10,
        "loop_limit": 1
      }
    ],
    "beforeShellExecution": [
      {
        "command": "node .cursor/hooks/guard-shell.mjs",
        "timeout": 5,
        "failClosed": false
      }
    ],
    "afterFileEdit": [
      {
        "command": "node .cursor/hooks/post-edit-reminder.mjs",
        "timeout": 5
      }
    ],
    "preToolUse": [
      {
        "command": "node .cursor/hooks/guard-write.mjs",
        "matcher": "Write",
        "timeout": 5,
        "failClosed": false
      }
    ]
  }
}
