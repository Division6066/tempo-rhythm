# ============================================================================
# Tempo Rhythm — Workspace Root Environment Variables
# ============================================================================
# This file is the canonical list of env vars consumed at the monorepo root
# (Convex backend, shared tooling) and across apps. Per-app `.env.local` files
# are git-ignored; only this `.env.example` is committed.
#
# Never commit real secret values. Real values live in:
#   - Convex dashboard (per-deployment env vars) for convex/ runtime
#   - Vercel project env vars for apps/web build + runtime
#   - EAS secrets for apps/mobile builds
#
# See docs/HARD_RULES.md §13 (Secrets and env vars).
# Placeholders use `REPLACE_ME` or obvious dummy values — never real tokens.
# ============================================================================

# #region Convex (required — `bun x convex dev` populates CONVEX_DEPLOYMENT)
# Convex deployment slug. Set automatically by `bun x convex dev`.
CONVEX_DEPLOYMENT=dev:your-project-name-here
# Production deploy key for CI / Vercel builds. Generate in Convex dashboard → Settings → Deploy Keys.
CONVEX_DEPLOY_KEY=REPLACE_ME
# Convex HTTP actions site URL (used for webhooks, OAuth callbacks).
CONVEX_SITE_URL=https://your-project-name.convex.site
# Public Convex URL for apps/web (ConvexReactClient). Mirrors CONVEX_SITE_URL.
NEXT_PUBLIC_CONVEX_URL=https://your-project-name.convex.cloud
# #endregion

# #region Auth — Convex Auth (HARD_RULES §2 — no Clerk/Auth0/NextAuth)
# Convex Auth signing secret. Generate with `openssl rand -base64 32`.
AUTH_SECRET=REPLACE_ME
# Canonical site origin used for magic-link + OAuth redirects (no trailing slash).
SITE_URL=http://localhost:3000
# #endregion

# #region AI — OpenRouter only (HARD_RULES §6 — no direct OpenAI/Anthropic/Google SDKs)
# OpenRouter API key for all LLM traffic. Set in Convex dashboard env vars for convex/ actions.
OPENROUTER_API_KEY=REPLACE_ME
# Public app name sent to OpenRouter for analytics / leaderboard attribution.
OPENROUTER_APP_NAME=tempo
# Public site URL sent to OpenRouter in the `HTTP-Referer` header.
OPENROUTER_SITE_URL=https://tempo.app
# #endregion

# #region Payments — RevenueCat (HARD_RULES §11 — server-side webhook verification)
# RevenueCat Android public key (ships client-side — safe to expose).
REVENUECAT_PUBLIC_KEY_ANDROID=REPLACE_ME
# RevenueCat iOS public key (ships client-side — safe to expose).
REVENUECAT_PUBLIC_KEY_IOS=REPLACE_ME
# RevenueCat Web public key (ships client-side — safe to expose).
REVENUECAT_PUBLIC_KEY_WEB=REPLACE_ME
# RevenueCat webhook signing secret. Server-only — never expose to client.
REVENUECAT_WEBHOOK_SECRET=REPLACE_ME
# #endregion

# #region Compliance — GetTerms document IDs (HARD_RULES §10)
# GetTerms cookies policy document ID.
TEMPO_GETTERMS_COOKIES_ID=REPLACE_ME
# GetTerms privacy policy document ID.
TEMPO_GETTERMS_PRIVACY_ID=REPLACE_ME
# GetTerms terms of service document ID.
TEMPO_GETTERMS_TERMS_ID=REPLACE_ME
# #endregion

# #region Analytics — PostHog (opt-in only, HARD_RULES §10)
# PostHog public project key. Ships client-side (safe to expose).
NEXT_PUBLIC_POSTHOG_KEY=REPLACE_ME
# PostHog ingestion host (EU region by default).
NEXT_PUBLIC_POSTHOG_HOST=https://eu.i.posthog.com
# #endregion

# #region Escalation — SMS + email fallbacks for nudge-ladder failures
# Resend API key used only for escalation emails (separate key from marketing).
RESEND_ESCALATION_API_KEY=REPLACE_ME
# Twilio webhook URL that relays inbound SMS back into the Convex action layer.
TWILIO_SMS_WEBHOOK=REPLACE_ME
# #endregion

# #region Agent HMAC secrets — shared-secret auth for external agent callbacks
# HMAC secret for Pokee (cross-SaaS orchestration) webhook signatures.
TEMPO_POKEE_HMAC_SECRET=REPLACE_ME
# HMAC secret for Twin (browser dashboard automation) webhook signatures.
TEMPO_TWIN_HMAC_SECRET=REPLACE_ME
# HMAC secret for Zo (long-running compute) webhook signatures.
TEMPO_ZO_HMAC_SECRET=REPLACE_ME
# #endregion

# #region Mobile — apps/mobile (Expo requires EXPO_PUBLIC_ prefix for client vars)
# Public Convex URL consumed by the Expo client (mirrors NEXT_PUBLIC_CONVEX_URL).
EXPO_PUBLIC_CONVEX_URL=https://your-project-name.convex.cloud
# RevenueCat Android public key for the Expo client (ships client-side).
EXPO_PUBLIC_REVENUECAT_ANDROID_KEY=REPLACE_ME
# RevenueCat iOS public key for the Expo client (ships client-side).
EXPO_PUBLIC_REVENUECAT_IOS_KEY=REPLACE_ME
# #endregion
