# ============================================================================
# Tempo Rhythm — Workspace Root Environment Variables
# ============================================================================
# This file is the canonical list of env vars consumed at the monorepo root
# (Convex backend, shared tooling). Per-app vars live in the app's own
# .env.example (apps/web/.env.example, apps/mobile/.env.local.example).
#
# Never commit real secret values. Real values live in:
#   - Convex dashboard (per-deployment env vars) for convex/ runtime
#   - Vercel project env vars for apps/web build + runtime
#   - EAS secrets for apps/mobile builds
#
# See docs/HARD_RULES.md §16.
# ============================================================================

# ----------------------------------------------------------------------------
# Convex (required — bun x convex dev generates/populates these)
# ----------------------------------------------------------------------------
# `CONVEX_DEPLOYMENT` is set automatically by `bun x convex dev`.
CONVEX_DEPLOYMENT=dev:your-project-name-here

# Public URL of the Convex deployment (used by apps/web via NEXT_PUBLIC_CONVEX_URL).
CONVEX_SITE_URL=https://your-project-name.convex.site

# Production deploy key for CI / Vercel builds. Generate in Convex dashboard:
# Settings → Deploy Keys → Generate Production Deploy Key. Never commit.
CONVEX_DEPLOY_KEY=

# ----------------------------------------------------------------------------
# Mistral (required for AI features)
# ----------------------------------------------------------------------------
# HARD_RULES §6 forbids direct OpenAI / Anthropic / Google AI SDKs and vendor
# AI SDKs. All LLM traffic flows through the Mistral API via native fetch
# (https://api.mistral.ai/v1/chat/completions). Set in Convex dashboard env
# vars for convex/ actions; set in Vercel env vars for any RSC-side calls.
MISTRAL_API_KEY=

# ----------------------------------------------------------------------------
# PostHog (opt-in analytics)
# ----------------------------------------------------------------------------
# Users must opt in via onboarding / Settings → Privacy (HARD_RULES §6).
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=https://eu.i.posthog.com

# ----------------------------------------------------------------------------
# RevenueCat (deferred — only required before production release)
# ----------------------------------------------------------------------------
# REVENUECAT_API_KEY=

# ----------------------------------------------------------------------------
# AI Features (legacy — superseded by MISTRAL_API_KEY above)
# ----------------------------------------------------------------------------
# These are kept here for reference only. All AI calls now route via Mistral.
# Remove once confirmed no callers reference these keys.
# AI_API_KEY=
# AI_PROVIDER=mistral
# AI_MODEL=mistral-small-latest

# ----------------------------------------------------------------------------
# Auth — magic-link email (Resend)
# ----------------------------------------------------------------------------
# Used by convex/auth.ts to send email magic-link verification messages.
# Required if you want the magic-link sign-in flow to work; otherwise the
# link is printed to the Convex backend logs (dev-only fallback).
# Sign up at https://resend.com and set in Convex dashboard env vars.
RESEND_API_KEY=
# From-address for magic-link emails. Defaults to "Tempo Flow <onboarding@resend.dev>".
# Use a verified Resend domain in production, e.g. "Tempo Flow <no-reply@yourdomain.com>".
RESEND_FROM_EMAIL=

# ----------------------------------------------------------------------------
# Beta gating (set in Convex dashboard env vars; NOT in Vercel / Next.js)
# ----------------------------------------------------------------------------
# Email of the founder account that bypasses the beta cap and receives
# god-tier + max subscription on first sign-in. Defaults to amitlevin65@protonmail.com.
BETA_FOUNDER_EMAIL=amitlevin65@protonmail.com
# Comma-separated list of additional emails that are allowed to sign up during
# the closed beta (founder is always added automatically).
BETA_ALLOWLIST_EMAILS=
# Maximum number of beta-tester accounts (not counting the founder). Default: 30.
BETA_MAX_TESTERS=30
