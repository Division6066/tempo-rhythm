# ============================================================================
# Tempo Rhythm - Workspace Root Environment Variables
# ============================================================================
# This file is for the shared Convex backend (workspace root).
# Run `bunx convex dev` from here to generate CONVEX_DEPLOYMENT.
# Then copy the values into both apps/.env files.

# Convex (Required)
CONVEX_DEPLOYMENT=dev:your-project-name-here
CONVEX_SITE_URL=https://your-project-name.convex.site

# ============================================================================
# AI Features (Optional - for memories/conversations extraction)
# ============================================================================
# Set in Convex dashboard environment variables, not local .env
# AI_API_KEY=
# AI_PROVIDER=gemini
# AI_MODEL=gemini-2.5-flash
