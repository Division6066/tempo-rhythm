# ============================================================================
# Tempo Rhythm — Workspace Root Environment Variables
# ============================================================================
# This file is the canonical list of env vars consumed at the monorepo root
# (Convex backend, shared tooling). Per-app vars live in the app's own
# .env.example (apps/web/.env.example, apps/mobile/.env.local.example).
#
# Never commit real secret values. Real values live in:
#   - Convex dashboard (per-deployment env vars) for convex/ runtime
#   - Vercel project env vars for apps/web build + runtime
#   - EAS secrets for apps/mobile builds
#
# See docs/HARD_RULES.md §16.
# ============================================================================

# ----------------------------------------------------------------------------
# Convex (required — bun x convex dev generates/populates these)
# ----------------------------------------------------------------------------
# `CONVEX_DEPLOYMENT` is set automatically by `bun x convex dev`.
CONVEX_DEPLOYMENT=dev:your-project-name-here

# Public URL of the Convex deployment (used by apps/web via NEXT_PUBLIC_CONVEX_URL).
CONVEX_SITE_URL=https://your-project-name.convex.site

# Production deploy key for CI / Vercel builds. Generate in Convex dashboard:
# Settings → Deploy Keys → Generate Production Deploy Key. Never commit.
CONVEX_DEPLOY_KEY=

# ----------------------------------------------------------------------------
# OpenRouter (required for AI features)
# ----------------------------------------------------------------------------
# HARD_RULES §6 forbids direct OpenAI / Anthropic / Google AI SDKs. All LLM
# traffic flows through OpenRouter via native fetch. Set in Convex dashboard
# env vars for convex/ actions; set in Vercel env vars for any RSC-side calls.
OPENROUTER_API_KEY=

# ----------------------------------------------------------------------------
# PostHog (opt-in analytics)
# ----------------------------------------------------------------------------
# Users must opt in via onboarding / Settings → Privacy (HARD_RULES §6).
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=https://eu.i.posthog.com

# ----------------------------------------------------------------------------
# RevenueCat (deferred — only required before production release)
# ----------------------------------------------------------------------------
# REVENUECAT_API_KEY=

# ----------------------------------------------------------------------------
# AI Features (legacy — prefer OPENROUTER_API_KEY above)
# ----------------------------------------------------------------------------
# These belong in the Convex dashboard, not a local .env. Listed here only so
# the shape is documented. Remove once all AI calls are routed via OpenRouter.
# AI_API_KEY=
# AI_PROVIDER=gemini
# AI_MODEL=gemini-2.5-flash
