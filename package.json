{
  "name": "tempo-rhythm",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@9.15.9",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "turbo run dev",
    "dev:web": "turbo run dev --filter=tempo-rhythm-web",
    "dev:mobile": "turbo run dev --filter=tempo-rhythm-mobile",
    "build": "turbo run build",
    "typecheck": "turbo run typecheck",
    "lint": "turbo run lint",
    "check": "turbo run check",
    "clean": "turbo run clean && rm -rf node_modules",
    "convex:dev": "npx convex dev",
    "convex:deploy": "npx convex deploy"
  },
  "dependencies": {
    "@convex-dev/auth": "^0.0.91",
    "convex": "^1.32.0"
  },
  "devDependencies": {
    "@types/node": "^20.19.0",
    "turbo": "^2.3.3"
  }
}
