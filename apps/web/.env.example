# ============================================================================
# apps/web — Web app environment variables
# ============================================================================
# Only vars consumed directly by the Next.js app at build/runtime live here.
# Shared backend/tooling vars live in the repo-root .env.example.
# HARD_RULES §16: never commit real values. Production values live in Vercel
# project env vars. Local dev values live in a `.env.local` (git-ignored).
# ============================================================================

# ----------------------------------------------------------------------------
# Convex (required at build and runtime)
# ----------------------------------------------------------------------------
# Public URL of the Convex deployment. Points to prod in production builds,
# dev/staging in preview builds. Mirrored from CONVEX_SITE_URL / the Convex
# dashboard.
NEXT_PUBLIC_CONVEX_URL=

# ----------------------------------------------------------------------------
# Analytics (opt-in — HARD_RULES §6)
# ----------------------------------------------------------------------------
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=https://eu.i.posthog.com

# ----------------------------------------------------------------------------
# Polar (billing — apps/web/app/checkout/route.ts, config/polarConfig.ts)
# ----------------------------------------------------------------------------
POLAR_ACCESS_TOKEN=
POLAR_SUCCESS_URL=
NEXT_PUBLIC_POLAR_MONTHLY_PRODUCT_ID=
NEXT_PUBLIC_POLAR_YEARLY_PRODUCT_ID=

# ----------------------------------------------------------------------------
# Legal links (optional — defaults to /terms and /privacy in appConfig.ts)
# ----------------------------------------------------------------------------
# NEXT_PUBLIC_TERMS_URL=
# NEXT_PUBLIC_PRIVACY_URL=
