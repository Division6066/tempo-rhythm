# ============================================================================
# apps/web — Web app environment variables
# ============================================================================
# See docs/ENVIRONMENTS.md for the four-mode contract.
# Only vars consumed directly by the Next.js app at build/runtime live here.
# Shared backend/tooling vars live in the repo-root .env.example.
# HARD_RULES §13: never commit real values. Production values live in Vercel
# project env vars. Local dev values live in a `.env.local` (git-ignored).
# ============================================================================

# ----------------------------------------------------------------------------
# Convex (required at build and runtime)
# ----------------------------------------------------------------------------
# Public URL of the Convex deployment consumed by the web app at build + runtime.
# This is the `.convex.cloud` URL — NOT the same as CONVEX_SITE_URL (`.convex.site`
# for Convex Auth). Copy from Convex dashboard → Settings → URL & Deploy Key.
# scope: [local] via apps/web/.env.local; [vercel production] via Vercel env table.
# Preview builds were disabled as of 2026-06-02 — see docs/ENVIRONMENTS.md.
NEXT_PUBLIC_CONVEX_URL=

# ----------------------------------------------------------------------------
# Analytics (opt-in — HARD_RULES §6)
# ----------------------------------------------------------------------------
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=https://eu.i.posthog.com

# ----------------------------------------------------------------------------
# Feature flags
# ----------------------------------------------------------------------------
# Set to "true" to expose the passkey (WebAuthn) settings page and sign-in
# button. Leave unset or empty to hide passkeys from the UI (flag-off state).
NEXT_PUBLIC_ENABLE_PASSKEYS=
