{
  "$schema": "https://biomejs.dev/schemas/2.3.8/schema.json",
  "extends": ["../../packages/config/biome.json"],
  "files": {
    "ignoreUnknown": false,
    "includes": [
      "**/*.ts",
      "**/*.tsx",
      "**/*.js",
      "**/*.jsx",
      "**/*.json",
      "**/*.css",
      "**/*.md",
      "!**/convex/_generated"
    ]
  },
  "css": {
    "parser": {
      "cssModules": true,
      "tailwindDirectives": true
    }
  }
}
