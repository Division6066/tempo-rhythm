{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "framework": null,
  "installCommand": "cd ../.. && bun install --frozen-lockfile",
  "buildCommand": "bunx expo export --platform web",
  "outputDirectory": "dist",
  "devCommand": "bunx expo start --web",
  "ignoreCommand": "bun x turbo-ignore tempo-rhythm-web || exit 1",
  "env": {
    "EXPO_NO_TELEMETRY": "1"
  }
}
