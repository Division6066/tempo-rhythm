{
  "$schema": "https://biomejs.dev/schemas/2.3.8/schema.json",
  "extends": ["../../packages/config/biome.json"],
  "files": {
    "ignoreUnknown": false,
    "includes": [
      "**/*",
      "!**/.expo",
      "!**/convex/_generated",
      "!**/components/__tests__",
      "!**/global.css",
      "!scripts"
    ]
  },
  "formatter": {
    "lineWidth": 80
  },
  "javascript": {
    "formatter": {
      "quoteStyle": "single",
      "trailingCommas": "es5"
    }
  },
  "overrides": [
    {
      "includes": ["convex/_generated/**", "global.css"],
      "linter": {
        "rules": {
          "suspicious": { "noExplicitAny": "off", "noUnknownAtRules": "off" },
          "correctness": { "noUnusedVariables": "off" },
          "complexity": { "noBannedTypes": "off" }
        }
      }
    }
  ]
}
