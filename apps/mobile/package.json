{
  "name": "tempo-rhythm-mobile",
  "main": "expo-router/entry",
  "version": "1.0.0",
  "scripts": {
    "postinstall": "node scripts/fix-all-metro-exports.js && node scripts/prune-empty-atypes.js",
    "dev": "node expo-start-windows.js",
    "web": "node expo-start-windows.js --web",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "lint": "biome lint .",
    "format": "biome format --write .",
    "check": "biome check --write .",
    "typecheck": "tsc --noEmit",
    "type-check": "tsc --noEmit",
    "type-check:watch": "tsc --noEmit --watch",
    "lint:full": "biome check . && bun run type-check",
    "check:full": "biome check --write . && bun run type-check",
    "ultracite": "ultracite",
    "check-deps": "bun scripts/check-deps.ts",
    "init-template": "bun scripts/init-template.ts",
    "setup-git-hooks": "bash scripts/setup-git-hooks.sh",
    "setup-shell-logging": "bash scripts/setup-shell-logging.sh"
  },
  "dependencies": {
    "@convex-dev/auth": "^0.0.94",
    "@expo/cli": "^57.0.9",
    "@expo/metro-runtime": "^57.0.6",
    "@expo/vector-icons": "^15.0.3",
    "@react-native-async-storage/async-storage": "^3.1.1",
    "@react-navigation/native": "^7.1.8",
    "@rn-primitives/slot": "^1.2.0",
    "@rn-primitives/types": "^1.2.0",
    "@tempo/ui": "workspace:*",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "compression": "^1.8.1",
    "convex": "^1.32.0",
    "expo": "~57.0.7",
    "expo-constants": "~57.0.6",
    "expo-font": "~57.0.1",
    "expo-linear-gradient": "~57.0.1",
    "expo-linking": "~57.0.3",
    "expo-localization": "^57.0.1",
    "expo-router": "~57.0.7",
    "expo-secure-store": "~57.0.1",
    "expo-splash-screen": "~57.0.4",
    "expo-status-bar": "~57.0.1",
    "expo-updates": "~57.0.8",
    "lucide-react-native": "^1.25.0",
    "nativewind": "^4.2.1",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "react-native": "0.86.0",
    "react-native-purchases": "^10.4.3",
    "react-native-reanimated": "~4.5.2",
    "react-native-safe-area-context": "~5.8.0",
    "react-native-screens": "~4.26.2",
    "react-native-svg": "15.15.5",
    "react-native-web": "^0.21.2",
    "react-native-webview": "14.0.1",
    "react-native-worklets": "0.11.1",
    "tailwind-merge": "^3.4.0"
  },
  "devDependencies": {
    "@biomejs/biome": "2.5.4",
    "@types/react": "~19.2.17",
    "chalk": "^5.3.0",
    "react-test-renderer": "19.2.7",
    "tailwindcss": "^4.3.3",
    "typescript": "~7.0.2",
    "ultracite": "^7.9.4"
  },
  "private": true
}
