{
  "name": "tempo-rhythm-mobile",
  "main": "expo-router/entry",
  "version": "1.0.0",
  "scripts": {
    "postinstall": "node scripts/fix-all-metro-exports.js && node scripts/prune-empty-atypes.js",
    "dev": "node expo-start-windows.js",
    "web": "node expo-start-windows.js --web",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "lint": "biome lint .",
    "format": "biome format --write .",
    "check": "biome check --write .",
    "typecheck": "tsc --noEmit",
    "type-check": "tsc --noEmit",
    "type-check:watch": "tsc --noEmit --watch",
    "lint:full": "biome check . && bun run type-check",
    "check:full": "biome check --write . && bun run type-check",
    "ultracite": "ultracite",
    "check-deps": "bun scripts/check-deps.ts",
    "init-template": "bun scripts/init-template.ts",
    "setup-git-hooks": "bash scripts/setup-git-hooks.sh",
    "setup-shell-logging": "bash scripts/setup-shell-logging.sh"
  },
  "dependencies": {
    "@convex-dev/auth": "^0.0.93",
    "@expo/cli": "^56.1.13",
    "@expo/metro-runtime": "^56.0.13",
    "@expo/vector-icons": "^15.0.3",
    "@react-native-async-storage/async-storage": "^3.1.1",
    "@react-navigation/native": "^7.1.8",
    "@rn-primitives/slot": "^1.2.0",
    "@rn-primitives/types": "^1.2.0",
    "@tempo/ui": "workspace:*",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "compression": "^1.8.1",
    "convex": "^1.32.0",
    "expo": "~56.0.8",
    "expo-constants": "~56.0.16",
    "expo-font": "~56.0.5",
    "expo-linear-gradient": "~56.0.4",
    "expo-linking": "~56.0.13",
    "expo-localization": "^56.0.6",
    "expo-router": "~56.2.8",
    "expo-secure-store": "~56.0.4",
    "expo-splash-screen": "~56.0.10",
    "expo-status-bar": "~56.0.4",
    "expo-updates": "~56.0.17",
    "lucide-react-native": "^1.17.0",
    "nativewind": "^4.2.1",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "react-native": "0.85.3",
    "react-native-purchases": "^10.2.0",
    "react-native-reanimated": "~4.4.0",
    "react-native-safe-area-context": "~5.8.0",
    "react-native-screens": "~4.25.2",
    "react-native-svg": "15.15.5",
    "react-native-web": "^0.21.2",
    "react-native-webview": "13.16.1",
    "react-native-worklets": "0.9.1",
    "tailwind-merge": "^3.4.0"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.16",
    "@types/react": "~19.2.16",
    "chalk": "^5.3.0",
    "react-test-renderer": "19.2.7",
    "tailwindcss": "^4.3.0",
    "typescript": "~6.0.3",
    "ultracite": "^7.8.1"
  },
  "private": true
}
